version: 0.1

log:
  level: info

storage:
  filesystem:
    rootdirectory: /var/lib/registry
  delete:
    enabled: true

http:
  addr: 0.0.0.0:5000
  host: {public_registry_origin}
  relativeurls: true
  headers:
    X-Content-Type-Options:
      - nosniff

notifications:
  events:
    includereferences: true
  endpoints:
    - name: registry-control-plane
      url: {internal_api_base_url}/api/internal/registry-events
      headers:
        Authorization:
          - Bearer {registry_notifications_token}
      timeout: 1s
      threshold: 5
      backoff: 1s
      ignoredmediatypes:
        - application/octet-stream
      ignore:
        mediatypes:
          - application/octet-stream
        actions:
          - pull
          - mount

auth:
  token:
    realm: {public_registry_origin}/auth/token
    service: {token_service}
    issuer: {token_issuer}
    rootcertbundle: /certs/auth-cert.pem
    signingalgorithms:
      - RS256
