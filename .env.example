# Copy this to .env for a persistent Docker deployment.
# The basic GHCR compose file starts in first-boot setup mode. Create the first
# admin and save the public registry origin from the browser.

# The default compose binding is localhost-only. Keep this behind a reverse
# proxy on the same host, or set a deliberate public bind such as 0.0.0.0:8080.
RCP_HTTP_BIND=127.0.0.1:8080

# Optional production settings. The Docker images already default to production
# mode with secure cookies, and the app owns safe defaults for the values below.
# Uncomment only when your deployment needs an override.
# FORWARDED_ALLOW_IPS=*

# docker-compose.ghcr.yml and docker-compose.bind-local.yml default to the
# public GHCR image set. Override these only if you want another registry mirror
# or a pinned tag.
# RCP_IMAGE_PREFIX=ghcr.io/sheldylew/registry-control-plane
# RCP_IMAGE_TAG=release
