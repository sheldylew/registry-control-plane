# Copy this to .env for a persistent Docker deployment.
# Leave the setup values blank to use the first-boot wizard, or set all four
# values to complete first-boot setup automatically from .env.

APP_ENV=production
PUBLIC_REGISTRY_ORIGIN=
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=

TOKEN_ISSUER=sheldylew-registry
TOKEN_SERVICE=sheldylew-registry
TOKEN_TTL_SECONDS=900
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_TOKEN_RATE_LIMIT_ATTEMPTS=10
AUTH_TOKEN_RATE_LIMIT_WINDOW_SECONDS=60
WEB_SESSION_RETENTION_DAYS=30
TOKEN_RECORD_RETENTION_DAYS=90

SESSION_COOKIE_SECURE=true
CSRF_TRUSTED_ORIGINS=
FORWARDED_ALLOW_IPS=*

# The default compose binding is localhost-only. Keep this behind a reverse
# proxy on the same host, or set a deliberate public bind such as 0.0.0.0:8080.
RCP_HTTP_BIND=127.0.0.1:8080

# If you publish images later, these can point at a tagged registry image set.
# For the current local packaging flow, docker compose builds from source.
# API_IMAGE=
# WEB_IMAGE=
